{
    "name": "nextjs-starter",
    "version": "1.0.0",
    "description": "A Next.js boilerplate project",
    "repository": "https://github.com/cryptenet/nextjs-starter.git",
    "author": "Alamgir Hossain <alamgir.h@cryptenet.com>",
    "license": "Apache 2.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 5000",
        "build": "next build",
        "start": "next start -p 5001",
        "prepare": "husky install",
        "type-check": "tsc --pretty --noEmit",
        "format": "prettier --write .",
        "lint": "eslint . --ext ts --ext tsx --ext js --fix",
        "test": "jest",
        "test-all": "pnpm format && pnpm lint && pnpm type-check && pnpm test && pnpm build"
    },
    "engines": {
        "node": ">=16.18.1",
        "npm": ">=8.19.2",
        "pnpm": ">=7.17.0",
        "yarn": ">=1.22.19"
    },
    "dependencies": {
        "@stitches/react": "^1.2.8",
        "framer-motion": "^7.6.9",
        "next": "^13.0.4",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-icons": "^4.6.0"
    },
    "devDependencies": {
        "@babel/core": "^7.20.2",
        "@commitlint/cli": "^17.3.0",
        "@commitlint/config-conventional": "^17.3.0",
        "@commitlint/types": "^17.0.0",
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "^13.4.0",
        "@types/jest": "^29.2.3",
        "@types/node": "^18.11.9",
        "@types/react": "^18.0.25",
        "@types/react-dom": "18.0.9",
        "@typescript-eslint/eslint-plugin": "^5.44.0",
        "@typescript-eslint/parser": "^5.44.0",
        "autoprefixer": "^10.4.13",
        "babel-jest": "^29.3.1",
        "babel-plugin-macros": "^3.1.0",
        "babel-plugin-twin": "^1.1.0",
        "eslint": "^8.28.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-next": "^13.0.4",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-import": "^2.26.0",
        "eslint-plugin-jsx-a11y": "^6.6.1",
        "eslint-plugin-prettier": "^4.2.1",
        "eslint-plugin-react": "^7.31.11",
        "eslint-plugin-react-hooks": "^4.6.0",
        "husky": "^8.0.0",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.3.1",
        "jest-environment-jsdom": "^29.3.1",
        "jest-watch-typeahead": "^2.2.1",
        "lint-staged": "^13.0.3",
        "postcss": "^8.4.19",
        "prettier": "^2.8.0",
        "tailwindcss": "^3.2.4",
        "twin.macro": "^3.0.1",
        "typescript": "^4.9.3"
    }
